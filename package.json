{
  "name": "lolev-beer",
  "version": "1.0.0",
  "description": "Lolev Beer brewery website with Payload CMS",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack -H 0.0.0.0",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "preview": "pnpm build && pnpm start",
    "clean": "rm -rf .next",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:a11y": "./scripts/test-accessibility.sh",
    "test:a11y:quick": "pnpm lint && pnpm type-check"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@payloadcms/db-mongodb": "3.79.1",
    "@payloadcms/next": "3.79.1",
    "@payloadcms/richtext-lexical": "3.79.1",
    "@payloadcms/storage-vercel-blob": "3.79.1",
    "@payloadcms/ui": "3.79.1",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-toggle": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@sentry/nextjs": "^10.63.0",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "diff": "^8.0.4",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.577.0",
    "mapbox-gl": "^3.25.0",
    "monaco-editor": "0.55.1",
    "next": "15.5.20",
    "next-themes": "^0.4.6",
    "nuqs": "^2.9.0",
    "payload": "3.79.1",
    "randomcolor": "^0.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.1",
    "sharp": "0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.58.2",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/react": "16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.9.4",
    "@types/randomcolor": "^0.5.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/blob": "^2.5.0",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.20",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "28.1.0",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.9.3",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=20",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "next": "15.5.20",
      "undici@5": "^6.27.0",
      "undici@6": "^6.27.0",
      "undici@7": "^7.28.0",
      "ajv": ">=8.18.0",
      "@opentelemetry/core": ">=2.8.0",
      "dompurify": ">=3.4.11",
      "esbuild": ">=0.28.1",
      "file-type": ">=21.3.1",
      "js-yaml": ">=4.2.0",
      "mongoose": ">=8.22.1",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1"
    },
    "patchedDependencies": {
      "next@15.5.20": "patches/next@15.5.20.patch"
    }
  }
}
