# Database
DATABASE_URI=mongodb://127.0.0.1/lolev-beer

# Payload CMS
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Vercel Blob Storage (for media uploads)
BLOB_READ_WRITE_TOKEN=

# Site URL (set automatically on Vercel, override for local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox (beer map page)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# Google Sheets sync (beer/menu/event/food data import)
GOOGLE_CSV_BEER=
GOOGLE_CSV_LAWRENCEVILLE_CANS=
GOOGLE_CSV_LAWRENCEVILLE_DRAFT=
GOOGLE_CSV_ZELIENOPLE_CANS=
GOOGLE_CSV_ZELIENOPLE_DRAFT=

# Cron & revalidation secrets
CRON_SECRET=
REVALIDATE_SECRET=

# Bing Maps (distributor geocoding)
BING_MAPS_API_KEY=

# Google Search Console verification
GOOGLE_SITE_VERIFICATION=
